    "/applications/{id}": {
      "put": {
        "tags": ["Applications"],
        "summary": "Update application status",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": ["Applied", "Shortlisted", "Rejected", "Hired"]
                  }
                }
              },
              "example": {
                "status": "Shortlisted"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Application updated successfully"
          },
          "404": {
            "description": "Application not found"
          }
        }
      },
      "delete": {
        "tags": ["Applications"],
        "summary": "Delete application",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Application deleted successfully"
          },
          "404": {
            "description": "Application not found"
          }
        }
      }
    },

    "/dashboard/stats": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "Get dashboard statistics",
        "responses": {
          "200": {
            "description": "Dashboard stats",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "totalJobs": { "type": "number" },
                    "totalApplicants": { "type": "number" },
                    "avgScore": { "type": "number" },
                    "applicationsByStatus": {
                      "type": "object",
                      "properties": {
                        "applied": { "type": "number" },
                        "shortlisted": { "type": "number" },
                        "rejected": { "type": "number" },
                        "hired": { "type": "number" }
                      }
                    }
                  }
                },
                "example": {
                  "totalJobs": 10,
                  "totalApplicants": 45,
                  "avgScore": 82,
