{
  "openapi": "3.0.0",
  "info": {
    "title": "TalentBoard + MessMate API",
    "version": "1.0.0",
    "description": "Complete API Documentation with Job Application Management"
  },

  "servers": [
    {
      "url": "http://localhost:3004"
    }
  ],

  "tags": [
    {
      "name": "Auth",
      "description": "Authentication APIs"
    },
    {
      "name": "MessMate",
      "description": "Mess management APIs"
    },
    {
      "name": "Jobs",
      "description": "Job CRUD APIs"
    },
    {
      "name": "Applications",
      "description": "Job application APIs"
    },
    {
      "name": "Dashboard",
      "description": "Dashboard statistics APIs"
    }
  ],

  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Application": {
        "type": "object",
        "properties": {
          "_id": { "type": "string", "example": "665abc123def456" },
          "jobId": { "type": "string", "example": "665abc123" },
          "userId": { "type": "string", "example": "665user123" },
          "fullName": { "type": "string", "example": "Nakul Kumar" },
          "email": { "type": "string", "example": "nakul@gmail.com" },
          "phone": { "type": "string", "example": "9876543210" },
          "dob": {
            "type": "string",
            "format": "date",
            "example": "1995-05-15"
          },
          "gender": {
            "type": "string",
            "enum": ["Male", "Female", "Other"],
            "example": "Male"
          },
          "address": { "type": "string", "example": "123 Main Street" },
          "city": { "type": "string", "example": "Mumbai" },
          "state": { "type": "string", "example": "Maharashtra" },
          "country": { "type": "string", "example": "India" },
          "pincode": { "type": "string", "example": "400001" },
          "aadhaar": { "type": "string", "example": "1234-5678-9012" },
          "pan": { "type": "string", "example": "ABCDE1234F" },
          "uan": { "type": "string", "example": "123456789012" },
          "tenthBoard": { "type": "string", "example": "CBSE" },
          "tenthPercentage": { "type": "number", "example": 88.5 },
          "tenthYear": { "type": "number", "example": 2012 },
          "twelfthBoard": { "type": "string", "example": "CBSE" },
          "twelfthPercentage": { "type": "number", "example": 85.5 },
          "twelfthYear": { "type": "number", "example": 2014 },
          "graduationCollege": {
            "type": "string",
            "example": "Mumbai University"
          },
          "graduationDegree": {
            "type": "string",
            "example": "B.E. Computer Science"
          },
          "graduationPercentage": { "type": "number", "example": 78.5 },
          "graduationYear": { "type": "number", "example": 2018 },
          "postGraduationCollege": {
            "type": "string",
            "example": "IIT Bombay"
          },
          "postGraduationDegree": { "type": "string", "example": "M.Tech CS" },
          "postGraduationPercentage": { "type": "number", "example": 82.5 },
          "postGraduationYear": { "type": "number", "example": 2020 },
          "experienceYears": { "type": "string", "example": "2" },
          "companyName": { "type": "string", "example": "Tech Corp" },
          "companyRole": { "type": "string", "example": "Software Developer" },
          "startDate": {
            "type": "string",
            "format": "date",
            "example": "2020-06-01"
          },
          "endDate": {
            "type": "string",
            "format": "date",
            "example": "2022-05-31"
          },
          "previousCompany": { "type": "string", "example": "Startup Inc" },
          "previousRole": { "type": "string", "example": "Intern" },
          "skills": {
            "type": "array",
            "items": { "type": "string" },
            "example": ["React", "Node.js", "MongoDB"]
          },
          "topSkills": {
            "type": "array",
            "items": { "type": "string" },
            "example": ["React", "Node.js"]
          },
          "github": { "type": "string", "example": "https://github.com/nakul" },
          "linkedin": {
            "type": "string",
            "example": "https://linkedin.com/in/nakul"
          },
          "portfolio": { "type": "string", "example": "https://nakul.dev" },
          "resume": { "type": "string", "example": "resume_nakul.pdf" },
          "coverLetter": {
            "type": "string",
            "example": "I am excited to apply..."
          },
          "acceptTerms": { "type": "boolean", "example": true },
          "confirmInformation": { "type": "boolean", "example": true },
          "aiScore": { "type": "number", "example": 85 },
          "status": {
            "type": "string",
            "enum": ["Applied", "Shortlisted", "Rejected", "Hired"],
            "example": "Applied"
          },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "Job": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "title": { "type": "string" },
          "profile": { "type": "string" },
          "company": { "type": "string" },
          "location": { "type": "string" },
          "salary": { "type": "string" },
          "type": { "type": "string" },
          "skillsRequired": { "type": "array", "items": { "type": "string" } },
          "experienceRequired": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  },

  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password", "confirmPassword"],
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "format": "password" },
                  "confirmPassword": { "type": "string", "format": "password" }
                }
              },
              "example": {
                "name": "Nakul Kumar",
                "email": "nakul@gmail.com",
                "password": "123456",
                "confirmPassword": "123456"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered successfully"
          },
          "400": {
            "description": "Validation error"
          }
        }
      }
    },

    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "format": "password" }
                }
              },
              "example": {
                "email": "nakul@gmail.com",
                "password": "123456"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login success",
            "content": {
              "application/json": {
                "example": {
                  "token": "eyJhbGciOiJIUzI1NiIs...",
                  "user": {
                    "id": "665user123",
                    "name": "Nakul Kumar",
                    "email": "nakul@gmail.com"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },

    "/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get logged in user profile",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "User profile data"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },

    "/health": {
      "get": {
        "tags": ["MessMate"],
        "summary": "Check API health",
        "responses": {
          "200": {
            "description": "Server running",
            "content": {
              "application/json": {
                "example": {
                  "status": "OK",
                  "message": "Server is running"
                }
              }
            }
          }
        }
      }
    },

    "/messes": {
      "get": {
        "tags": ["MessMate"],
        "summary": "Get all messes",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "List of messes"
          }
        }
      },
      "post": {
        "tags": ["MessMate"],
        "summary": "Create new mess",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "name": "Student Mess",
                "location": "Campus Area",
                "capacity": 200,
                "mealType": ["Breakfast", "Lunch", "Dinner"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Mess created successfully"
          }
        }
      }
    },

    "/messes/{id}": {
      "get": {
        "tags": ["MessMate"],
        "summary": "Get mess by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Single mess data"
          },
          "404": {
            "description": "Mess not found"
          }
        }
      },
      "put": {
        "tags": ["MessMate"],
        "summary": "Update mess",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Mess updated"
          }
        }
      },
      "delete": {
        "tags": ["MessMate"],
        "summary": "Delete mess",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Mess deleted"
          }
        }
      }
    },

    "/jobs": {
      "get": {
        "tags": ["Jobs"],
        "summary": "Get all jobs",
        "responses": {
          "200": {
            "description": "Jobs list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Job" }
                }
              }
            }
          }
        }
      }
    },

    "/jobs/create": {
      "post": {
        "tags": ["Jobs"],
        "summary": "Create job",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "profile", "company"],
                "properties": {
                  "title": { "type": "string" },
                  "profile": { "type": "string" },
                  "company": { "type": "string" },
                  "location": { "type": "string" },
                  "salary": { "type": "string" },
                  "type": { "type": "string" },
                  "skillsRequired": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "experienceRequired": { "type": "string" },
                  "description": { "type": "string" }
                }
              },
              "example": {
                "title": "Frontend Developer",
                "profile": "React Developer",
                "company": "Google",
                "location": "Remote",
                "salary": "12 LPA",
                "type": "Full Time",
                "skillsRequired": ["React", "JavaScript", "CSS"],
                "experienceRequired": "2 years",
                "description": "React developer required for exciting projects"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Job created successfully"
          },
          "400": {
            "description": "Validation error"
          }
        }
      }
    },

    "/jobs/{id}": {
      "get": {
        "tags": ["Jobs"],
        "summary": "Get job by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Single job",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Job" }
              }
            }
          },
          "404": {
            "description": "Job not found"
          }
        }
      },
      "put": {
        "tags": ["Jobs"],
        "summary": "Update job",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Job updated"
          }
        }
      },
      "delete": {
        "tags": ["Jobs"],
        "summary": "Delete job",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Job deleted"
          }
        }
      }
    },

    "/applications": {
      "get": {
        "tags": ["Applications"],
        "summary": "Get all job applications",
        "responses": {
          "200": {
            "description": "Application list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Application" }
                }
              }
            }
          }
        }
      }
    },

    "/applications/apply": {
